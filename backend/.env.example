# Copy this file to `.env` (same folder) and fill in your values.
# Everything is optional - with no .env the app runs on the built-in demo data.

# --- Tier 1: Nexar / Octopart (global distributor prices, stock, lead time) ---
# Get these from https://portal.nexar.com -> create an application.
# This is the single most important key: it makes real part numbers return
# real offers. Free "Evaluation" app = ~100 parts total, so test sparingly.
NEXAR_CLIENT_ID=
NEXAR_CLIENT_SECRET=

# How many offers to pull per part (each returned part counts toward your limit).
NEXAR_LIMIT=5
# Prioritise offers that can ship to this country (ISO-2).
NEXAR_SHIP_TO=IN

# --- Database (where cached offers + saved runs are stored) -------------------
# Default is a local SQLite file - no setup needed. To use a hosted DB instead,
# put its URL here, e.g.:
#   postgresql+psycopg://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./rfq_ai.db
# How long cached offers stay fresh before re-querying the source (hours).
CACHE_TTL_HOURS=24

# --- Tier 2: Shopify / WooCommerce distributor stores ------------------------
# Path to a JSON file listing stores you have credentials for.
# See stores.example.json. Leave blank to disable.
STORES_CONFIG=
